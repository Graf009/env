#!/usr/bin/env bash
#
# vvv — system diagnostics (read-only)
#
# Reports device management, background services, privacy permissions and
# active network connections. It ONLY reads the system — it never changes,
# removes, unloads or disables anything.
#
# Usage:
#   vvv              summary
#   vvv -v           verbose (adds component vendor detail)
#   vvv --full       elevated read for full daemon/profile visibility (sudo)
#   vvv --no-color   disable color
#   vvv --plain      pipe-friendly output (no color, tab-separated)
#   vvv -h           this help
#
# Exit codes: 0 = nothing flagged · 1 = one or more candidates · 2 = run error

set -uo pipefail

ORIG_ARGS=("$@")

VERBOSE=0
COLOR=auto
PLAIN=0
FULL=0

usage() { sed -n '3,17p' "$0" | sed 's/^# \{0,1\}//'; }

while [ $# -gt 0 ]; do
  case "$1" in
    -v|--verbose) VERBOSE=1 ;;
    --no-color)   COLOR=off ;;
    --plain)      PLAIN=1; COLOR=off ;;
    --full)       FULL=1 ;;
    -h|--help)    usage; exit 0 ;;
    *) printf 'vvv: unknown option: %s\n' "$1" >&2; exit 2 ;;
  esac
  shift
done

# Elevated read: re-exec self under sudo, then proceed as root (no loop —
# the child sees FULL but is already root). sudo only widens READ visibility.
if [ "$FULL" -eq 1 ] && [ "$(id -u)" -ne 0 ]; then
  exec sudo "$0" "${ORIG_ARGS[@]}"
fi

IS_ROOT=0; [ "$(id -u)" -eq 0 ] && IS_ROOT=1

# ---------- presentation (neutral) ----------
if [ "$COLOR" = auto ]; then
  if [ -t 1 ]; then COLOR=on; else COLOR=off; fi
fi
if [ "$COLOR" = on ]; then
  DIM=$'\033[2m'; BLD=$'\033[1m'; RST=$'\033[0m'
else
  DIM=""; BLD=""; RST=""
fi

FLAGGED=0
ERRORS=0

section() { printf '\n%s%s%s\n' "$BLD" "$1" "$RST"; }
# row COMPONENT STATUS DETAIL
row() {
  if [ "$PLAIN" -eq 1 ]; then
    printf '%s\t%s\t%s\n' "$1" "$2" "$3"
  else
    printf '  %-22s %-14s %s\n' "$1" "$2" "$3"
  fi
}
detail() { [ -n "$1" ] && printf '  %s%s%s\n' "$DIM" "$1" "$RST"; }

have() { command -v "$1" >/dev/null 2>&1; }
need() {  # required tool; on absence emit a neutral row and count an error
  if have "$1"; then return 0; fi
  row "$2" "unavailable" "tool '$1' not found"
  ERRORS=$((ERRORS + 1))
  return 1
}

# ---------- signatures: pattern|short-tag|vendor ----------
SIGNATURES=(
  "jamf|device-management|Jamf (MDM)"
  "kandji|device-management|Kandji (MDM)"
  "mosyle|device-management|Mosyle (MDM)"
  "intune|device-management|Microsoft Intune (MDM)"
  "companyportal|device-management|Intune Company Portal (MDM)"
  "addigy|device-management|Addigy (MDM)"
  "airwatch|device-management|Workspace ONE / AirWatch (MDM)"
  "hexnode|device-management|Hexnode (MDM)"
  "meraki|device-management|Cisco Meraki SM (MDM)"
  "crowdstrike|endpoint-security|CrowdStrike Falcon (EDR)"
  "sentinelone|endpoint-security|SentinelOne (EDR)"
  "carbonblack|endpoint-security|Carbon Black (EDR)"
  "cylance|endpoint-security|Cylance (EDR)"
  "netskope|network-control|Netskope (network control / DLP)"
  "forcepoint|network-control|Forcepoint (DLP)"
  "teramind|activity-tracking|Teramind (activity monitoring)"
  "hubstaff|activity-tracking|Hubstaff (activity tracker)"
  "timedoctor|activity-tracking|Time Doctor (activity tracker)"
  "activtrak|activity-tracking|ActivTrak (activity monitoring)"
  "veriato|activity-tracking|Veriato (activity monitoring)"
  "worksmart|activity-tracking|Crossover WorkSmart (activity tracker)"
  "interguard|activity-tracking|InterGuard (activity monitoring)"
  "spytech|activity-tracking|Spytech (activity monitoring)"
  "defender|endpoint-security|Microsoft Defender (EDR)"
  "falcon|endpoint-security|CrowdStrike Falcon (EDR)"
  "sentinel|endpoint-security|SentinelOne (EDR)"
  "crossover|activity-tracking|Crossover WorkSmart (activity tracker)"
)
# Common dictionary words — matched only on token boundaries to cut false hits.
ANCHORED=" defender falcon sentinel crossover "

# sig_match HAYSTACK_LOWER  → prints "short|vendor" on first hit, else nothing
sig_match() {
  local hay="$1" sig pat short vendor re
  for sig in "${SIGNATURES[@]}"; do
    pat="${sig%%|*}"; short="${sig#*|}"; vendor="${short#*|}"; short="${short%%|*}"
    if [[ "$ANCHORED" == *" $pat "* ]]; then
      re="(^|[^a-z0-9])${pat}([^a-z0-9]|\$)"
    else
      re="$pat"
    fi
    if printf '%s' "$hay" | grep -qE "$re"; then
      printf '%s|%s' "$short" "$vendor"
      return 0
    fi
  done
  return 1
}

printf '%ssystem diagnostics%s  %s  %s\n' "$BLD" "$RST" \
  "$(hostname -s 2>/dev/null)" "$(date '+%Y-%m-%d %H:%M')"
if [ "$IS_ROOT" -eq 0 ]; then
  detail "some checks need elevated read access — re-run: vvv --full"
fi

# ============================================================
section "Device management"
# ============================================================
if need profiles "enrollment"; then
  enroll="$(profiles status -type enrollment 2>/dev/null)"
  if printf '%s' "$enroll" | grep -qiE 'MDM enrollment:[[:space:]]*Yes'; then
    if printf '%s' "$enroll" | grep -qiE 'DEP:[[:space:]]*Yes|via DEP: Yes'; then
      row "enrollment" "managed" "MDM active, enrolled via DEP/ADE"
    else
      row "enrollment" "managed" "MDM enrollment active"
    fi
    FLAGGED=$((FLAGGED + 1))
  else
    row "enrollment" "not managed" "no MDM enrollment"
  fi

  prof="$(profiles list 2>/dev/null || true)"
  if [ -n "${prof:-}" ] && ! printf '%s' "$prof" | grep -qi 'no configuration'; then
    pcount="$(printf '%s\n' "$prof" | grep -ciE 'attribute: name|profileIdentifier')"
    [ "$pcount" -eq 0 ] && pcount="present"
    row "config profiles" "$pcount present" "installed configuration profiles"
    FLAGGED=$((FLAGGED + 1))
    if [ "$VERBOSE" -eq 1 ]; then
      printf '%s' "$prof" | grep -iE 'attribute: name|profileIdentifier' | sed 's/^/      /'
    fi
  else
    row "config profiles" "none" "no user configuration profiles visible"
  fi
fi

MP="/Library/Managed Preferences"
if [ -d "$MP" ] && [ -n "$(ls -A "$MP" 2>/dev/null)" ]; then
  mpc="$(ls -1 "$MP" 2>/dev/null | wc -l | tr -d ' ')"
  row "managed prefs" "present" "$mpc domain(s) enforced"
  FLAGGED=$((FLAGGED + 1))
  [ "$VERBOSE" -eq 1 ] && ls -1 "$MP" 2>/dev/null | sed 's/^/      /'
else
  row "managed prefs" "none" "no enforced preference domains"
fi

# ============================================================
section "Background services"
# ============================================================
scan_dir() {
  local dir="$1" label="$2"
  if [ ! -d "$dir" ]; then row "$label" "absent" "$dir"; return 0; fi
  local files count=0 hits=0 f low hit short vendor
  files="$(ls -1 "$dir" 2>/dev/null)"
  local matched=()
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    count=$((count + 1))
    low="$(printf '%s' "$f" | tr '[:upper:]' '[:lower:]')"
    if hit="$(sig_match "$low")"; then
      short="${hit%%|*}"; vendor="${hit#*|}"
      hits=$((hits + 1))
      matched+=("$f|$short|$vendor")
    fi
  done <<< "$files"
  if [ "$hits" -gt 0 ]; then
    row "$label" "$count items" "$hits candidate — $(printf '%s' "${matched[0]#*|}" | cut -d'|' -f1)"
    FLAGGED=$((FLAGGED + hits))
    for m in "${matched[@]}"; do
      if [ "$VERBOSE" -eq 1 ]; then
        detail "${m%%|*}  →  ${m##*|}  (candidate — verify in System Settings)"
      else
        detail "${m%%|*}  (candidate: $(printf '%s' "$m" | cut -d'|' -f2))"
      fi
    done
  else
    row "$label" "$count items" "no known-vendor signatures"
  fi
}
scan_dir "/Library/LaunchDaemons"      "LaunchDaemons"
scan_dir "/Library/LaunchAgents"       "LaunchAgents"
scan_dir "$HOME/Library/LaunchAgents"  "user LaunchAgents"

if need launchctl "loaded services"; then
  lc="$(launchctl list 2>/dev/null)"
  lhits=0
  low_lc="$(printf '%s' "$lc" | tr '[:upper:]' '[:lower:]')"
  for sig in "${SIGNATURES[@]}"; do
    pat="${sig%%|*}"; rest="${sig#*|}"; short="${rest%%|*}"; vendor="${rest#*|}"
    if [[ "$ANCHORED" == *" $pat "* ]]; then re="(^|[^a-z0-9])${pat}([^a-z0-9]|\$)"; else re="$pat"; fi
    if printf '%s' "$low_lc" | grep -qE "$re"; then
      lhits=$((lhits + 1)); FLAGGED=$((FLAGGED + 1))
      if [ "$VERBOSE" -eq 1 ]; then
        detail "loaded: $pat  →  $vendor  (candidate)"
      else
        detail "loaded: $pat  (candidate: $short)"
      fi
    fi
  done
  [ "$lhits" -eq 0 ] && row "loaded services" "ok" "no known-vendor signatures loaded"
fi

# ============================================================
section "Installed components"
# ============================================================
CHECK_PATHS=(
  "/usr/local/jamf|device-management|Jamf"
  "/Library/Application Support/JAMF|device-management|Jamf"
  "/Applications/Company Portal.app|device-management|Intune"
  "/Applications/Falcon.app|endpoint-security|CrowdStrike Falcon"
  "/Library/CS|endpoint-security|CrowdStrike"
  "/Applications/SentinelOne|endpoint-security|SentinelOne"
  "/Library/Sentinel|endpoint-security|SentinelOne"
  "/Library/Application Support/Netskope|network-control|Netskope"
  "/Applications/Microsoft Defender.app|endpoint-security|Microsoft Defender"
  "/Library/Kandji|device-management|Kandji"
  "/Library/Addigy|device-management|Addigy"
  "/Applications/Teramind.app|activity-tracking|Teramind"
  "/Applications/Hubstaff.app|activity-tracking|Hubstaff"
  "/Applications/Time Doctor.app|activity-tracking|Time Doctor"
)
phits=0
for cp in "${CHECK_PATHS[@]}"; do
  p="${cp%%|*}"; rest="${cp#*|}"; short="${rest%%|*}"; vendor="${rest#*|}"
  if [ -e "$p" ]; then
    phits=$((phits + 1)); FLAGGED=$((FLAGGED + 1))
    if [ "$VERBOSE" -eq 1 ]; then
      row "$short" "present" "$vendor — $p"
    else
      row "$short" "present" "$(basename "$p")"
    fi
  fi
done
[ "$phits" -eq 0 ] && row "known vendors" "none" "no known-vendor install paths found"

# ============================================================
section "Privacy permissions"
# ============================================================
tcc_report() {
  local db="$1" scope="$2"
  [ -f "$db" ] || return 0
  if ! have sqlite3; then return 0; fi
  if ! sqlite3 "$db" "SELECT 1;" >/dev/null 2>&1; then
    row "tcc ($scope)" "restricted" "grant Full Disk Access to the terminal to read"
    return 0
  fi
  local out
  out="$(sqlite3 "$db" \
    "SELECT service, client FROM access WHERE auth_value>0 AND service IN \
     ('kTCCServiceScreenCapture','kTCCServiceListenEvent', \
      'kTCCServiceAccessibility','kTCCServiceSystemPolicyAllFiles', \
      'kTCCServicePostEvent');" 2>/dev/null)"
  if [ -z "$out" ]; then
    row "tcc ($scope)" "clean" "no sensitive grants"
    return 0
  fi
  printf '%s\n' "$out" | while IFS='|' read -r svc client; do
    case "$svc" in
      kTCCServiceScreenCapture)        label="screen recording" ;;
      kTCCServiceListenEvent)          label="input capture" ;;
      kTCCServicePostEvent)            label="input synthesis" ;;
      kTCCServiceAccessibility)        label="accessibility" ;;
      kTCCServiceSystemPolicyAllFiles) label="full disk access" ;;
      *)                               label="$svc" ;;
    esac
    row "$label" "granted" "$client"
  done
}
tcc_report "$HOME/Library/Application Support/com.apple.TCC/TCC.db" "user"
[ "$IS_ROOT" -eq 1 ] && tcc_report "/Library/Application Support/com.apple.TCC/TCC.db" "system"
detail "review in System Settings → Privacy & Security (screen recording, keyboard input, accessibility, full disk access)"

# ============================================================
section "Active connections"
# ============================================================
if need lsof "connections"; then
  conns="$(lsof -nP -iTCP -sTCP:ESTABLISHED 2>/dev/null | awk 'NR>1 {print $1}' | sort | uniq -c | sort -rn | head -15)"
  if [ -n "$conns" ]; then
    printf '%s\n' "$conns" | while read -r c name; do
      row "$name" "$c conn" "established outbound"
    done
  else
    row "connections" "none" "no established outbound TCP"
  fi
fi

# ============================================================
if [ "$PLAIN" -eq 0 ]; then printf '\n'; fi
if [ "$FLAGGED" -gt 0 ]; then
  printf '%s%d component(s) flagged for review%s\n' "$BLD" "$FLAGGED" "$RST"
fi

if [ "$ERRORS" -gt 0 ]; then exit 2; fi
if [ "$FLAGGED" -gt 0 ]; then exit 1; fi
exit 0
