# Template for ~/.fish.env — copy to home dir and fill in values.
# This file is loaded by fish/config.fish on every shell start.
# The real ~/.fish.env must never be committed to source control.
#
# Preferred workflow: store all values in Bitwarden as a secure note
# named "fish.env", then run `bw-env` to pull them into ~/.fish.env.

GITHUB_TOKEN=
YC_TOKEN=
ANTHROPIC_API_KEY=
MATTERMOST_TOKEN=
