# identity — loaded by gitdir match; podeli is also the fallback
[includeIf "gitdir:~/project/ecom/"]
    path = .gitconfig-ecom
[includeIf "gitdir:~/project/public/"]
    path = .gitconfig-public
[includeIf "gitdir:~/project/tmp/"]
    path = .gitconfig-public

[user]
    name = Oleg Orlov

[core]
    autocrlf = input
    editor   = micro
    pager    = delta

[init]
    defaultBranch = main

[branch]
    autosetuprebase = always

[push]
    default = current

[commit]
    gpgsign = true

[gpg]
    format = ssh

[gpg "ssh"]
    allowedSignersFile = ~/.config/git/allowed_signers

[alias]
    current-branch = "!git branch 2>/dev/null | sed -e '/^[^*]/d' -e 's/* \\(.*\\)/\\1/'"
    a  = "!git add . && git s"
    s  = status --short --branch
    d  = diff
    c  = commit -m
    ac = commit -am
    ch = checkout
    l  = "!git pull origin $(git current-branch) --rebase"
    h  = "!git push origin $(git current-branch)"
    lh = "!git l && git h"
    r  = "!git rm $(git ls-files --deleted) && git status"
    lg = log --pretty=format:'%Cred%h%Creset%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)%an%Creset' --abbrev-commit
    tree = log --oneline --graph --decorate

[color]
    diff   = auto
    status = auto
    branch = auto

[credential]
    helper = osxkeychain

[filter "lfs"]
    process  = git-lfs filter-process
    required = true
    clean    = git-lfs clean -- %f
    smudge   = git-lfs smudge -- %f
